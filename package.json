{
  "name": "prompt-injection-detector",
  "version": "1.0.0",
  "description": "Browser extension that detects prompt injection techniques on web pages",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:chrome": "node build.mjs --chrome",
    "build:firefox": "node build.mjs --firefox",
    "lint:firefox": "cd dist/firefox && web-ext lint",
    "test": "node --test test/scanner.test.js test/threat-model.test.js",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "web-ext": "^8.4.0"
  }
}
